@inject ILayoutService LayoutService
@implements IDisposable;
@page "/"
@using NYC311Dashboard.Services.Contracts

<PageTitle>Home</PageTitle>


<div class="home-page-container">
    <div class="home-page-title">Welcome to the NYC 311 Dashboard!</div>
    <img class="nyc-home-image" src="images/nyc_background.png" alt="New York City" />
</div>
<div class="home-page-content">
    <p class="home-page-intro">
        Explore New York City's non-emergency 311 service requests —
        visualised and broken down across the five boroughs.
    </p>
    <div class="home-page-cards">
        <div class="home-page-card">
            <i class="bi bi-geo-alt-fill"></i>
            <span>Borough</span>
        </div>
        <div class="home-page-card">
            <i class="bi bi-mailbox"></i>
            <span>Zip Code</span>
        </div>
        <div class="home-page-card">
            <i class="bi bi-shield-fill"></i>
            <span>Precinct</span>
        </div>
    </div>
    <a href="/boroughs" class="home-page-cta">Explore the data</a>
</div>

@code {

    protected override void OnInitialized()
    {
        LayoutService.SetTitle("NYC 311 Dashboard");
    }
    protected override async Task OnInitializedAsync()
    {
        LayoutService.SetSidebar(null);
        //await LayoutService.ToggleClassName("article", "content");
    }

    public void Dispose()
    {
        //LayoutService.ToggleClassName("article", "content");
    }
}